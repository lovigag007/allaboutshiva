{% extends "admin/layout.njk" %}
{% block content %}
<form method="POST" action="/admin/stotras{% if not isNew %}/{{ item.id }}{% endif %}" class="admin-form">
  <div class="form-group">
    <label>Title *</label>
    <input type="text" name="title" value="{{ item.title }}" required class="form-control">
  </div>
  <div class="form-group">
    <label>Stotra Text *</label>
    <textarea name="text" required class="form-control sanskrit-input" rows="10" placeholder="Full stotra text…">{{ item.text }}</textarea>
  </div>
  <div class="form-group">
    <label>Meaning *</label>
    <textarea name="meaning" required class="form-control" rows="8">{{ item.meaning }}</textarea>
  </div>
  <div class="form-group">
    <label>Written By (optional)</label>
    <input type="text" name="written_by" value="{{ item.written_by }}" class="form-control" placeholder="e.g. Adi Shankaracharya">
  </div>
  <div class="form-group">
    <label>Story / History (optional)</label>
    <textarea name="story" class="form-control" rows="6">{{ item.story }}</textarea>
  </div>
  <div class="form-row">
    <div class="form-group form-check">
      <label><input type="checkbox" name="is_featured" {% if item.is_featured %}checked{% endif %}> Featured</label>
    </div>
    <div class="form-group">
      <label>Sort Order</label>
      <input type="number" name="sort_order" value="{{ item.sort_order or 0 }}" class="form-control" style="width:100px">
    </div>
  </div>
  <div class="form-actions">
    <button type="submit" class="btn-admin-primary">{% if isNew %}Create Stotra{% else %}Update Stotra{% endif %}</button>
    <a href="/admin/stotras" class="btn-admin-outline">Cancel</a>
  </div>
</form>
{% endblock %}
