{% extends "admin/layout.njk" %}
{% block content %}
<div class="table-toolbar">
  <form method="GET" class="search-bar">
    <input type="text" name="search" value="{{ search }}" placeholder="Search stotras…" class="form-control">
    <button type="submit" class="btn-admin-primary">Search</button>
    {% if search %}<a href="/admin/stotras" class="btn-admin-outline">Clear</a>{% endif %}
  </form>
  <a href="/admin/stotras/new" class="btn-admin-primary">+ New Stotra</a>
</div>
<div class="table-wrap">
  <table class="admin-table">
    <thead><tr><th>Title</th><th>Written By</th><th>Featured</th><th>Actions</th></tr></thead>
    <tbody>
      {% for item in rows %}
      <tr>
        <td><strong>{{ item.title }}</strong></td>
        <td>{{ item.written_by or '—' }}</td>
        <td>{% if item.is_featured %}<span class="badge-yes">Yes</span>{% else %}<span class="badge-no">No</span>{% endif %}</td>
        <td class="actions">
          <a href="/admin/stotras/{{ item.id }}/edit" class="btn-sm">Edit</a>
          <form method="POST" action="/admin/stotras/{{ item.id }}/delete" style="display:inline;" onsubmit="return confirm('Delete?')">
            <button type="submit" class="btn-sm btn-danger">Delete</button>
          </form>
        </td>
      </tr>
      {% else %}
      <tr><td colspan="4" class="empty-row">No stotras found.</td></tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% endblock %}
