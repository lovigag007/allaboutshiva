{% extends "admin/layout.njk" %}
{% block content %}
<form method="POST" action="/admin/names{% if not isNew %}/{{ item.id }}{% endif %}" class="admin-form">
  <div class="form-row">
    <div class="form-group">
      <label>Name *</label>
      <input type="text" name="name" value="{{ item.name }}" required class="form-control" placeholder="e.g. Neelakantha">
    </div>
    <div class="form-group">
      <label>Language</label>
      <input type="text" name="language" value="{{ item.language or 'Sanskrit' }}" class="form-control">
    </div>
  </div>
  <div class="form-group">
    <label>Meaning *</label>
    <textarea name="meaning" required class="form-control" rows="3" placeholder="What this name means…">{{ item.meaning }}</textarea>
  </div>
  <div class="form-group">
    <label>Story Behind This Name</label>
    <textarea name="story" class="form-control" rows="6" placeholder="The mythological or spiritual story behind this name…">{{ item.story }}</textarea>
  </div>
  <div class="form-row">
    <div class="form-group form-check">
      <label>
        <input type="checkbox" name="is_featured" {% if item.is_featured %}checked{% endif %}> Show on homepage (Featured)
      </label>
    </div>
    <div class="form-group">
      <label>Sort Order</label>
      <input type="number" name="sort_order" value="{{ item.sort_order or 0 }}" class="form-control" style="width:100px">
    </div>
  </div>
  <div class="form-actions">
    <button type="submit" class="btn-admin-primary">{% if isNew %}Create Name{% else %}Update Name{% endif %}</button>
    <a href="/admin/names" class="btn-admin-outline">Cancel</a>
  </div>
</form>
{% endblock %}
