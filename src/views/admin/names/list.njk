{% extends "admin/layout.njk" %}
{% block content %}
<div class="table-toolbar">
  <form method="GET" class="search-bar">
    <input type="text" name="search" value="{{ search }}" placeholder="Search names…" class="form-control">
    <button type="submit" class="btn-admin-primary">Search</button>
    {% if search %}<a href="/admin/names" class="btn-admin-outline">Clear</a>{% endif %}
  </form>
  <a href="/admin/names/new" class="btn-admin-primary">+ New Name</a>
</div>
<div class="table-wrap">
  <table class="admin-table">
    <thead>
      <tr><th>Name</th><th>Language</th><th>Meaning</th><th>Featured</th><th>Actions</th></tr>
    </thead>
    <tbody>
      {% for item in rows %}
      <tr>
        <td><strong>{{ item.name }}</strong></td>
        <td>{{ item.language }}</td>
        <td>{{ item.meaning | truncate(60) }}</td>
        <td>{% if item.is_featured %}<span class="badge-yes">Yes</span>{% else %}<span class="badge-no">No</span>{% endif %}</td>
        <td class="actions">
          <a href="/admin/names/{{ item.id }}/edit" class="btn-sm">Edit</a>
          <form method="POST" action="/admin/names/{{ item.id }}/delete" style="display:inline;" onsubmit="return confirm('Delete this name?')">
            <button type="submit" class="btn-sm btn-danger">Delete</button>
          </form>
        </td>
      </tr>
      {% else %}
      <tr><td colspan="5" class="empty-row">No names found.</td></tr>
      {% endfor %}
    </tbody>
  </table>
</div>
<div class="table-footer">Showing {{ rows.length }} of {{ total }} records</div>
{% endblock %}
