{% extends "admin/layout.njk" %}
{% block content %}
<form method="POST" action="/admin/mantras{% if not isNew %}/{{ item.id }}{% endif %}" class="admin-form">
  <div class="form-group">
    <label>Title *</label>
    <input type="text" name="title" value="{{ item.title }}" required class="form-control" placeholder="e.g. Om Namah Shivaya">
  </div>
  <div class="form-group">
    <label>Sanskrit Text *</label>
    <textarea name="text_sanskrit" required class="form-control sanskrit-input" rows="5" placeholder="Sanskrit text…">{{ item.text_sanskrit }}</textarea>
  </div>
  <div class="form-group">
    <label>English Transliteration *</label>
    <textarea name="text_english" required class="form-control" rows="5" placeholder="Romanized transliteration…">{{ item.text_english }}</textarea>
  </div>
  <div class="form-group">
    <label>Meaning *</label>
    <textarea name="meaning" required class="form-control" rows="5" placeholder="What this mantra means…">{{ item.meaning }}</textarea>
  </div>
  <div class="form-group">
    <label>Source (optional)</label>
    <input type="text" name="source" value="{{ item.source }}" class="form-control" placeholder="e.g. Rigveda 7.59.12">
  </div>
  <div class="form-group">
    <label>Story / History (optional)</label>
    <textarea name="story" class="form-control" rows="6">{{ item.story }}</textarea>
  </div>
  <div class="form-row">
    <div class="form-group form-check">
      <label>
        <input type="checkbox" name="is_featured" {% if item.is_featured %}checked{% endif %}> Featured
      </label>
    </div>
    <div class="form-group">
      <label>Sort Order</label>
      <input type="number" name="sort_order" value="{{ item.sort_order or 0 }}" class="form-control" style="width:100px">
    </div>
  </div>
  <div class="form-actions">
    <button type="submit" class="btn-admin-primary">{% if isNew %}Create Mantra{% else %}Update Mantra{% endif %}</button>
    <a href="/admin/mantras" class="btn-admin-outline">Cancel</a>
  </div>
</form>
{% endblock %}
