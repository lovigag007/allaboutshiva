{% extends "admin/layout.njk" %}
{% block content %}
<form method="POST" action="/admin/pages{% if not isNew %}/{{ item.id }}{% endif %}" class="admin-form">
  <div class="form-row">
    <div class="form-group" style="flex:1">
      <label>URL Slug *</label>
      <input type="text" name="slug" value="{{ item.slug }}" required class="form-control" placeholder="e.g. about-us">
      <small style="color:var(--muted)">Accessible at /page/your-slug</small>
    </div>
    <div class="form-group" style="flex:2">
      <label>Page Title *</label>
      <input type="text" name="title" value="{{ item.title }}" required class="form-control">
    </div>
  </div>
  <div class="form-group">
    <label>Content (HTML supported)</label>
    <textarea name="content" class="form-control" rows="20" placeholder="<h2>About...</h2><p>...</p>">{{ item.content }}</textarea>
  </div>
  <div class="form-group form-check">
    <label><input type="checkbox" name="is_active" {% if item.is_active or isNew %}checked{% endif %}> Page is active (visible to public)</label>
  </div>
  <div class="form-actions">
    <button type="submit" class="btn-admin-primary">{% if isNew %}Create Page{% else %}Update Page{% endif %}</button>
    <a href="/admin/pages" class="btn-admin-outline">Cancel</a>
  </div>
</form>
{% endblock %}
