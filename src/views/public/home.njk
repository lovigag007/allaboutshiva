{% extends "public/layout.njk" %}

{% block content %}

<!-- HERO SECTION -->
<section class="hero">
  <div class="hero-bg"></div>
  <div class="hero-content">
    <div class="hero-idol-wrap">
      <div class="shiva-idol-svg">
        <!-- Artistic SVG representation of Shiva in meditation pose -->
        <svg viewBox="0 0 300 520" xmlns="http://www.w3.org/2000/svg" class="shiva-svg">
          <!-- Glow aura -->
          <defs>
            <radialGradient id="aura" cx="50%" cy="40%" r="50%">
              <stop offset="0%" stop-color="#f5c842" stop-opacity="0.25"/>
              <stop offset="100%" stop-color="#c06000" stop-opacity="0"/>
            </radialGradient>
            <radialGradient id="bodyGlow" cx="50%" cy="50%" r="50%">
              <stop offset="0%" stop-color="#e8d5b0" stop-opacity="0.4"/>
              <stop offset="100%" stop-color="#8b5500" stop-opacity="0"/>
            </radialGradient>
            <filter id="glow">
              <feGaussianBlur stdDeviation="4" result="coloredBlur"/>
              <feMerge><feMergeNode in="coloredBlur"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
          </defs>
          <!-- Aura background -->
          <ellipse cx="150" cy="200" rx="130" ry="160" fill="url(#aura)"/>
          <!-- Jata (matted hair) -->
          <path d="M110,80 Q90,30 120,10 Q150,0 150,0 Q150,0 180,10 Q210,30 190,80" fill="none" stroke="#8b6914" stroke-width="3" stroke-linecap="round"/>
          <path d="M100,85 Q80,45 105,20 Q130,5 150,2" fill="none" stroke="#8b6914" stroke-width="2.5" stroke-linecap="round"/>
          <path d="M200,85 Q220,45 195,20 Q170,5 150,2" fill="none" stroke="#8b6914" stroke-width="2.5" stroke-linecap="round"/>
          <!-- Crescent moon in jata -->
          <path d="M138,22 Q148,12 158,22 Q148,16 138,22" fill="#f5e6a3" stroke="#d4af37" stroke-width="1"/>
          <!-- Ganga flowing from hair -->
          <path d="M115,40 Q100,70 95,120 Q90,160 88,200" fill="none" stroke="#7ec8e3" stroke-width="2" stroke-linecap="round" opacity="0.7"/>
          <!-- Head -->
          <ellipse cx="150" cy="105" rx="42" ry="48" fill="#d4a76a"/>
          <!-- Third eye -->
          <ellipse cx="150" cy="95" rx="6" ry="3.5" fill="#cc2200" filter="url(#glow)"/>
          <ellipse cx="150" cy="95" rx="3" ry="2" fill="#ff6644"/>
          <!-- Eyes closed - meditation -->
          <path d="M132,108 Q142,112 152,108" fill="none" stroke="#5c3a1e" stroke-width="2" stroke-linecap="round"/>
          <path d="M148,108 Q158,112 168,108" fill="none" stroke="#5c3a1e" stroke-width="2" stroke-linecap="round"/>
          <!-- Nose -->
          <path d="M148,115 Q145,122 148,126 Q152,128 155,126 Q158,122 152,115" fill="#c4926a" stroke="#a07040" stroke-width="0.5"/>
          <!-- Mouth - serene smile -->
          <path d="M138,135 Q150,143 162,135" fill="none" stroke="#8b5e3c" stroke-width="2" stroke-linecap="round"/>
          <!-- Vibhuti (ash lines) on forehead -->
          <line x1="132" y1="89" x2="168" y2="89" stroke="#f0f0f0" stroke-width="2" stroke-linecap="round"/>
          <line x1="135" y1="84" x2="165" y2="84" stroke="#f0f0f0" stroke-width="1.5" stroke-linecap="round"/>
          <line x1="138" y1="79" x2="162" y2="79" stroke="#f0f0f0" stroke-width="1.5" stroke-linecap="round"/>
          <!-- Neck -->
          <rect x="138" y="148" width="24" height="25" rx="5" fill="#d4a76a"/>
          <!-- Neelakantha (blue throat) -->
          <ellipse cx="150" cy="158" rx="10" ry="8" fill="#4a7a9b" opacity="0.7"/>
          <!-- Rudraksha mala on neck -->
          <ellipse cx="150" cy="172" rx="20" ry="8" fill="none" stroke="#6b3a1f" stroke-width="3" stroke-dasharray="4,3"/>
          <!-- Serpent at neck -->
          <path d="M125,165 Q118,155 125,148 Q133,142 140,148" fill="none" stroke="#2d6e2d" stroke-width="3.5" stroke-linecap="round"/>
          <ellipse cx="124" cy="148" rx="5" ry="4" fill="#2d6e2d"/>
          <!-- Body (seated, lotus pose) -->
          <path d="M100,175 Q85,220 88,300 Q90,360 150,380 Q210,360 212,300 Q215,220 200,175 Q180,165 150,165 Q120,165 100,175Z" fill="#c8956a"/>
          <!-- Sacred thread -->
          <path d="M130,175 Q140,240 142,320" fill="none" stroke="#f5e6a3" stroke-width="2" opacity="0.9"/>
          <!-- Right arm holding Trishula -->
          <path d="M200,175 Q230,180 240,200 Q245,220 238,250" fill="none" stroke="#c8956a" stroke-width="18" stroke-linecap="round"/>
          <!-- Trishula -->
          <line x1="238" y1="250" x2="238" y2="170" stroke="#d4af37" stroke-width="3"/>
          <path d="M231,175 Q238,165 245,175" fill="none" stroke="#d4af37" stroke-width="2.5"/>
          <path d="M225,178 Q238,162 251,178" fill="none" stroke="#d4af37" stroke-width="2.5"/>
          <!-- Left arm - Damaru -->
          <path d="M100,175 Q70,180 60,200 Q55,220 62,250" fill="none" stroke="#c8956a" stroke-width="18" stroke-linecap="round"/>
          <!-- Damaru -->
          <g transform="translate(53,248)">
            <path d="M0,0 L16,10 L0,20 Z" fill="#8b4513"/>
            <path d="M20,0 L4,10 L20,20 Z" fill="#8b4513"/>
            <line x1="10" y1="0" x2="10" y2="20" stroke="#d4af37" stroke-width="1.5"/>
            <circle cx="0" cy="10" r="2" fill="#d4af37"/>
            <circle cx="20" cy="10" r="2" fill="#d4af37"/>
          </g>
          <!-- Lotus position legs -->
          <path d="M88,300 Q60,340 70,380 Q100,400 150,395 Q200,400 230,380 Q240,340 212,300" fill="#c8956a"/>
          <!-- Tiger skin -->
          <path d="M95,310 Q150,330 205,310 Q190,380 150,390 Q110,380 95,310Z" fill="#d4a830" opacity="0.5"/>
          <!-- Feet -->
          <ellipse cx="100" cy="390" rx="22" ry="12" fill="#c8956a"/>
          <ellipse cx="200" cy="390" rx="22" ry="12" fill="#c8956a"/>
          <!-- Lotus flower base -->
          <ellipse cx="150" cy="410" rx="70" ry="20" fill="#d4567a" opacity="0.6"/>
          <ellipse cx="150" cy="408" rx="55" ry="16" fill="#e87aaa" opacity="0.5"/>
          <!-- Small decorative lotuses -->
          <circle cx="95" cy="408" r="8" fill="#e87aaa" opacity="0.4"/>
          <circle cx="205" cy="408" r="8" fill="#e87aaa" opacity="0.4"/>
          <!-- Base/platform -->
          <rect x="60" y="420" width="180" height="18" rx="4" fill="#8b6914" opacity="0.6"/>
          <!-- Sanskrit text at base -->
          <text x="150" y="455" text-anchor="middle" font-family="serif" font-size="14" fill="#d4af37" opacity="0.85">ॐ नमः शिवाय</text>
        </svg>
      </div>
    </div>

    <div class="hero-text">
      <h1 class="hero-title">Har Har Mahadev</h1>
      <p class="hero-subtitle">हर हर महादेव</p>
      <p class="hero-desc">Explore the infinite wisdom, sacred names, ancient mantras, and divine stories of the Eternal Mahadeva — the Auspicious One, the First Yogi, the Lord of the Universe.</p>
      <div class="hero-cta">
        <a href="/names" class="btn-primary">Explore Names</a>
        <a href="/mantras" class="btn-secondary">Sacred Mantras</a>
      </div>
    </div>
  </div>
</section>

<!-- RANDOM NAMES SECTION -->
<section class="section names-section">
  <div class="container">
    <div class="section-header">
      <span class="section-tag">The Thousand Names</span>
      <h2 class="section-title">Names of the Mahadeva</h2>
      <p class="section-desc">Each name of Shiva is a universe unto itself — carrying meaning, myth, and devotion across millennia.</p>
    </div>
    <div class="names-grid">
      {% for name in featuredNames %}
      <a href="/names/{{ name.id }}" class="name-card">
        <div class="name-devanagari">ॐ</div>
        <h3 class="name-title">{{ name.name }}</h3>
        <p class="name-meaning">{{ name.meaning | truncate(80) }}</p>
      </a>
      {% endfor %}
    </div>
    <div class="section-more">
      <a href="/names" class="btn-outline">View All Names →</a>
    </div>
  </div>
</section>

<!-- UPCOMING EVENTS SECTION -->
{% if upcomingEvents and upcomingEvents.length > 0 %}
<section class="section events-section">
  <div class="container">
    <div class="section-header">
      <span class="section-tag">Auspicious Occasions</span>
      <h2 class="section-title">Upcoming Sacred Events</h2>
      <p class="section-desc">Mark your calendar for the most auspicious occasions dedicated to Lord Shiva.</p>
    </div>
    <div class="events-list">
      {% for event in upcomingEvents %}
      <div class="event-card">
        <div class="event-date-block">
          <span class="event-day">{{ event.event_date | dateformat }}</span>
          {% if event.day_name %}<span class="event-weekday">{{ event.day_name }}</span>{% endif %}
        </div>
        <div class="event-info">
          <h3 class="event-name">{{ event.event_name }}</h3>
          {% if event.mahurat_time %}<p class="event-mahurat">🕉️ Muhurat: {{ event.mahurat_time }}</p>{% endif %}
          {% if event.description %}<p class="event-desc">{{ event.description | truncate(150) }}</p>{% endif %}
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

<!-- QUICK LINKS SECTION -->
<section class="section explore-section">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Explore the Sacred</h2>
    </div>
    <div class="explore-grid">
      <a href="/mantras" class="explore-card">
        <div class="explore-icon">🕉️</div>
        <h3>Mantras</h3>
        <p>Sacred chants from the Vedas and tradition</p>
      </a>
      <a href="/vedas" class="explore-card">
        <div class="explore-icon">📜</div>
        <h3>Vedas</h3>
        <p>The four eternal sources of divine knowledge</p>
      </a>
      <a href="/stotras" class="explore-card">
        <div class="explore-icon">🙏</div>
        <h3>Stotras</h3>
        <p>Hymns of devotion composed by great saints</p>
      </a>
      <a href="/ornaments" class="explore-card">
        <div class="explore-icon">🌙</div>
        <h3>Ornaments</h3>
        <p>The meaning behind every symbol Shiva wears</p>
      </a>
    </div>
  </div>
</section>

{% endblock %}
